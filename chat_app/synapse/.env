NODE_TLS_REJECT_UNAUTHORIZED=0

SERVER_NAME=twake.local
BASE_URL=https://tom.twake.local
OIDC_ISSUER=https://auth.twake.local/
TRUSTED_PROXIES=uniquelocal

AUTH_URL=https://auth.twake.local
MATRIX_ADMIN_LOGIN=dwho
MATRIX_ADMIN_PASSWORD=dwho

ADDITIONAL_FEATURES=false
FEDERATED_IDENTITY_SERVICES=fed.twake.local

CRON_SERVICE=true
UPDATE_FEDERATED_IDENTITY_HASHES_CRON="0-59/2 * * * *"
UPDATE_USERS_CRON="1-59/2 * * * *"

DATABASE_ENGINE=pg
DATABASE_HOST=postgres
DATABASE_NAME=tom
DATABASE_USER=twake
DATABASE_PASSWORD=twake!1


# USERDB_ENGINE=sqlite
# USERDB_HOST=./lemon.db

USERDB_ENGINE=ldap
LDAP_URI=ldap://ldap
#LDAP_BASE=ou=users,dc=twake,dc=local
#LDAP_FILTER=(objectClass=inetOrgPerson)
LDAP_BASE=ou=users,dc=twake,dc=local
LDAP_FILTER=(&(|(uid=$user)(mail=$user))(objectClass=inetOrgPerson))
LDAP_USER=cn=admin,dc=twake,dc=local 
LDAP_PASSWORD=admin


# USERDB_HOST=/opt/lemon/db/lemon.db
# LDAP_PASSWORD="T0m_p@Ss"

MATRIX_INTERNAL_HOST=matrix.twake.local
MATRIX_SERVER=matrix.twake.local
MATRIX_DATABASE_ENGINE=pg
MATRIX_DATABASE_HOST=postgres
MATRIX_DATABASE_NAME=synapse
MATRIX_DATABASE_USER=synapse
MATRIX_DATABASE_PASSWORD='synapse!1'

SMS_API_KEY=SOME_SECRET_KEY
SMS_API_LOGIN=login@domain.com
SMS_API_URL=https://api.octopush.com/v1/public

LOG_LEVEL=silly
LOG_TRANSPORTS=Console

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=user
RABBITMQ_PASSWORD=pass
RABBITMQ_TLS=false

FEATURE_COMMON_SETTINGS_ENABLED=false
FEATURE_COMMON_SETTINGS_QUEUE=chat.settings.updated.queue
FEATURE_COMMON_SETTINGS_EXCHANGE="settings exchange"
FEATURE_COMMON_SETTINGS_ROUTING_KEY="user.settings.updated"
